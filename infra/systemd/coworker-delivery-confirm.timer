[Unit]
Description=Periodic 4h delivery-confirmation sweep for CoWorker v3
Requires=coworker-delivery-confirm.service

[Timer]
# Run every 30 minutes. The 4h confirmation window is generous,
# so the sweep cadence isn't sensitive; 30min keeps the cost
# proportional and the worst-case dwell short (a successful send
# flips to 'delivered' within 4h + 30min from creation).
OnBootSec=5min
OnUnitActiveSec=30min
AccuracySec=1min
Persistent=true

[Install]
WantedBy=timers.target
